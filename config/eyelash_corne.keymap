#define ZMK_POINTING_DEFAULT_MOVE_VAL 1200  // 600
#define ZMK_POINTING_DEFAULT_SCRL_VAL 25   // 10

#include <input/processors.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/rgb.h>

&mmv_input_listener { input-processors = <&zip_xy_scaler 2 1>; };

&msc_input_listener { input-processors = <&zip_scroll_scaler 2 1>; };

&msc {
    acceleration-exponent = <1>;      // 0
    time-to-max-speed-ms = <100>;       // 300
    delay-ms = <0>;                   // 0
};

&mmv {
    time-to-max-speed-ms = <500>;
    acceleration-exponent = <1>;
    trigger-period-ms = <16>;
};

&soft_off { hold-time-ms = <2000>; };

/ {
    behaviors {
        mt: mod_tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <180>;
            bindings = <&kp>, <&kp>;

            display-name = "Mod-Tap";
            quick-tap-ms = <120>;
        };

        lt: layer_tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <180>;
            bindings = <&mo>, <&kp>;

            display-name = "Layer-Tap";
            quick-tap-ms = <120>;
        };

        rgb_encoder: rgb_encoder {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&rgb_ug RGB_BRI>, <&rgb_ug RGB_BRD>;
        };

        scroll_encoder: scroll_encoder {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;

            tap-ms = <100>;
        };

        h_mt: home_row_mod_tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&kp>;

            display-name = "Mod-Tap";
            label = "H_MT";
        };
    };

    combos {
        compatible = "zmk,combos";

        softoff {
            bindings = <&soft_off>;
            key-positions = <1 15 29>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "QWERTY";
            bindings = <
&kp ESCAPE  &kp Q        &mt RALT W   &kp E       &kp R      &kp T                              &kp UP                &kp Y         &kp U        &kp I           &mt RALT O     &kp P           &kp BACKSLASH
&kp TAB     &kp A        &kp S        &kp D       &kp F      &kp G                    &kp LEFT  &kp ENTER  &kp RIGHT  &kp H         &kp J        &kp K           &kp L          &kp SEMI        &kp SQT
&kp LSHIFT  &mt LCTRL Z  &mt LMETA X  &mt LALT C  &kp V      &kp B       &kp SPACE              &kp DOWN              &kp N         &kp M        &mt RALT COMMA  &mt RMETA DOT  &mt RCTRL FSLH  &kp RSHIFT
                                      &tog 3      &kp SPACE  &lt 4 BSPC                                               &lt 6 DELETE  &lt 5 ENTER  &mo 7
            >;

            sensor-bindings = <&inc_dec_kp C_VOLUME_UP C_VOL_DN>;
        };

        hmods {
            bindings = <
&trans  &trans        &trans         &trans          &trans         &trans                    &trans          &trans  &trans         &trans          &trans         &trans                &trans
&trans  &h_mt RALT A  &h_mt LMETA S  &h_mt LSHIFT D  &h_mt LCTRL F  &trans            &trans  &trans  &trans  &trans  &h_mt RCTRL J  &h_mt RSHIFT K  &h_mt RMETA L  &h_mt RALT SEMICOLON  &trans
&trans  &trans        &trans         &trans          &trans         &trans  &trans            &trans          &trans  &trans         &trans          &trans         &trans                &trans
                                     &trans          &trans         &trans                                    &trans  &trans         &trans
            >;

            label = "hmods";
        };

        sthumb {
            bindings = <
&trans  &trans  &trans  &trans  &trans      &trans                       &trans          &trans       &trans        &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans               &trans  &trans  &trans  &trans       &trans        &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans      &trans     &trans            &trans          &trans       &trans        &trans  &trans  &trans  &trans
                        &tog 3  &lt 4 BSPC  &kp SPACE                                    &lt 5 ENTER  &lt 6 DELETE  &mo 7
            >;

            label = "sthumb";
        };

        gaming {
            bindings = <
&trans  &kp T      &kp Q  &kp W   &kp E   &kp R                     &trans          &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp LSHFT  &kp A  &kp S   &kp D   &kp F             &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp LCTRL  &kp Z  &kp X   &kp C   &kp V   &trans            &trans          &trans  &trans  &trans  &trans  &trans  &trans
                          &tog 3  &trans  &trans                                    &trans  &trans  &trans
            >;

            label = "GAMING";
        };

        symbols {
            bindings = <
&trans  &kp LS(EXCL)   &kp LS(AT)    &kp LS(POUND)  &kp LS(DLLR)  &kp LS(PRCNT)                    &trans          &kp LS(CARET)  &kp LS(AMPS)  &kp LS(STAR)  &trans         &trans    &trans
&trans  &kp LS(LBRC)   &kp LS(LPAR)  &kp LS(RPAR)   &kp LS(RBRC)  &kp EQUAL                &trans  &trans  &trans  &kp GRAVE      &kp LS(DQT)   &kp SQT       &kp LS(UNDER)  &kp BSLH  &trans
&trans  &kp LS(TILDE)  &kp LBKT      &kp RBKT       &kp MINUS     &kp LS(PLUS)   &trans            &trans          &trans         &kp LS(PIPE)  &kp LS(LT)    &kp LS(GT)     &trans    &trans
                                     &trans         &trans        &trans                                           &trans         &trans        &trans
            >;

            label = "SYMBOLS";
        };

        numbers {
            bindings = <
&trans  &trans  &kp N7  &kp N8  &kp N9  &trans                    &trans          &trans    &trans    &trans  &trans     &trans  &trans
&trans  &kp N0  &kp N4  &kp N5  &kp N6  &trans            &trans  &trans  &trans  &kp LEFT  &kp DOWN  &kp UP  &kp RIGHT  &trans  &trans
&trans  &trans  &kp N1  &kp N2  &kp N3  &trans  &trans            &trans          &trans    &trans    &trans  &trans     &trans  &trans
                        &trans  &trans  &trans                                    &trans    &trans    &trans
            >;

            label = "NUMBERS";
        };

        system {
            bindings = <
&trans  &kt PG_UP  &mkp RCLK       &mmv MOVE_UP    &mkp LCLK        &trans                            &trans          &trans             &trans            &trans      &trans      &trans  &trans
&trans  &kt PG_DN  &mmv MOVE_LEFT  &mmv MOVE_DOWN  &mmv MOVE_RIGHT  &msc SCRL_UP              &trans  &trans  &trans  &kp C_VOLUME_UP    &kp C_PLAY_PAUSE  &trans      &trans      &trans  &trans
&trans  &trans     &trans          &mkp MCLK       &trans           &msc SCRL_DOWN  &trans            &trans          &kp C_VOLUME_DOWN  &kp K_MUTE        &kp C_PREV  &kp C_NEXT  &trans  &trans
                                   &trans          &trans           &trans                                            &trans             &trans            &trans
            >;

            label = "SYSTEM";
        };

        keyboard {
            bindings = <
&bt BT_CLR_ALL  &trans           &trans           &trans           &tog 1           &tog 2                             &trans                     &trans  &trans  &trans  &trans  &trans  &trans
&bt BT_CLR      &bt BT_SEL 0     &bt BT_SEL 1     &bt BT_SEL 2     &bt BT_SEL 3     &bt BT_SEL 4               &trans  &ext_power EP_TOG  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&bootloader     &rgb_ug RGB_TOG  &rgb_ug RGB_EFR  &rgb_ug RGB_EFF  &rgb_ug RGB_SPD  &rgb_ug RGB_SPI  &trans            &trans                     &trans  &trans  &trans  &trans  &trans  &bootloader
                                                  &trans           &trans           &trans                                                        &trans  &trans  &trans
            >;

            label = "KEYBOARD";
            sensor-bindings = <&rgb_encoder>;
        };

        old1 {
            display-name = "old1";
            bindings = <
&trans  &kp N1           &kp N2          &kp N3        &kp N4        &kp N5                                         &mmv MOVE_UP                     &kp N6           &kp N7           &kp N8           &kp N9           &kp N0    &kp BSPC
&trans  &bt BT_CLR_ALL   &bt BT_SEL 0    &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3                   &mmv MOVE_LEFT  &mkp LCLK       &mmv MOVE_RIGHT  &kp LEFT         &kp DOWN         &kp UP           &kp RIGHT        &kp HOME  &kp PG_UP
&trans  &rgb_ug RGB_OFF  &rgb_ug RGB_ON  &trans        &trans        &rgb_ug RGB_EFF  &kp C_MUTE                    &mmv MOVE_DOWN                   &rgb_ug RGB_EFR  &rgb_ug RGB_SPI  &rgb_ug RGB_BRI  &rgb_ug RGB_BRD  &kp END   &kp PG_DN
                                         &trans        &trans        &trans                                                                          &kp INS          &kp DEL          &trans
            >;

            sensor-bindings = <&scroll_encoder>;
        };
    };
};
